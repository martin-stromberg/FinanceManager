{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "FinanceManager.Web.Infrastructure.RequestLoggingMiddleware": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5003"
      }
    }
  },
  "Jwt": {
    "Issuer": "financemanager",
    "Audience": "financemanager",
    "LifetimeMinutes": 30
  },
  "AlphaVantage": {
    "Quota": {
      "MaxSymbolsPerRun": 8,
      "RequestsPerMinute": 4
    }
  },
  "BackgroundTasks": {
    "Enabled": true
  },
  "Workers": {
    "SecurityPriceWorker": {
      "Enabled": true
    }
  },
  "Updates": {
    "Enabled": false,
    "HostedServicesEnabled": true,
    "CheckIntervalMinutes": 360,
    "RepositoryOwner": "martin-stromberg",
    "RepositoryName": "FinanceManager",
    "ManifestAssetName": "update.json",
    "WorkingDirectory": "updates",
    "HealthTimeoutSeconds": 120,
    "MaxAssetBytes": 536870912
  },
  "DetailedErrors": true,
  "FileLogging": {
    "Enabled": true,
    "PathFormat": "logs/app-{date}.log",
    "RetainedFileCountLimit": 10,
    "FileSizeLimitBytes": 10485760,
    "RollOnFileSizeLimit": true,
    "Append": true,
    "IncludeScopes": false,
    "UseUtcTimestamp": false
  }
}
