{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 20971520
    }
  },
  "Jwt": {
    "Key": "",
    "Issuer": "financemanager",
    "Audience": "financemanager",
    "LifetimeMinutes": 30
  },
  "AlphaVantage": {
    "Quota": {
      "MaxSymbolsPerRun": 8,
      "RequestsPerMinute": 4
    }
  },
  "BackgroundTasks": {
    "Enabled": true
  },
  "Workers": {
    "SecurityPriceWorker": {
      "Enabled": true
    }
  },
  "Updates": {
    "Enabled": false,
    "HostedServicesEnabled": true,
    "CheckIntervalMinutes": 360,
    "RepositoryOwner": "martin-stromberg",
    "RepositoryName": "FinanceManager",
    "ManifestAssetName": "update.json",
    "WorkingDirectory": "updates",
    "ServiceName": null,
    "HealthTimeoutSeconds": 120,
    "MaxAssetBytes": 536870912
  },
  "Backups": {
    "Security": {
      "MaxUploadBytes": 104857600,
      "MaxCompressedZipBytes": 104857600,
      "MaxUncompressedNdjsonBytes": 262144000,
      "MaxZipEntries": 1,
      "MaxCompressionRatio": 25,
      "AllowedEntryNames": [
        "backup.ndjson"
      ],
      "AllowedEntryPrefixes": [
        "backup-"
      ],
      "AllowedBackupVersions": [
        3
      ]
    }
  },
  "FileLogging": {
    "Enabled": false,
    "PathFormat": "logs/app-{date}.log",
    "RetainedFileCountLimit": 30,
    "FileSizeLimitBytes": 10485760,
    "RollOnFileSizeLimit": true,
    "Append": true,
    "IncludeScopes": false,
    "UseUtcTimestamp": false
  },
  "Identity": {
    "Lockout": {
      "DefaultLockoutMinutes": 5,
      "MaxFailedAccessAttempts": 3,
      "AllowedForNewUsers": true
    },
    "Password": {
      "RequireDigit": true,
      "RequiredLength": 8,
      "RequireNonAlphanumeric": false
    }
  }
}
