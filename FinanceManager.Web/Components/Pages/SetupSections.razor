@using FinanceManager.Web.ViewModels.Setup
@using Microsoft.AspNetCore.Components
@inject IServiceProvider Services

@if (Provider == null)
{
    <div>@("Loading...")</div>
}
else
{
    <div class="setup-sections setup-sections-accordion">
        @foreach (var kv in Provider.SettingSections)
        {
            var key = kv.Key;
            var isExpanded = _expandedSections.Contains(key);
            <section class="setup-section-accordion-item">
                <button type="button" class="setup-section-toggle" @onclick="() => ToggleSection(key)" aria-expanded="@isExpanded">
                    <span class="setup-section-toggle-title">@kv.Value</span>
                    <span class="setup-section-toggle-icon" aria-hidden="true">@(isExpanded ? "−" : "+")</span>
                </button>

                @if (isExpanded)
                {
                    var spec = BuildSectionSpec(key);
                    if (spec.ComponentType != null)
                    {
                        <div class="setup-section-content">
                            <DynamicComponent Type="spec.ComponentType" Parameters="spec.Parameters" />
                        </div>
                    }
                }
            </section>
        }
    </div>
}

@code {
    [Parameter] public SetupCardViewModel? Provider { get; set; }

    private readonly HashSet<string> _expandedSections = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, object> _viewModels = new(StringComparer.OrdinalIgnoreCase);

    private void ToggleSection(string key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        if (!_expandedSections.Add(key))
        {
            _expandedSections.Remove(key);
        }
    }

    private (Type? ComponentType, IDictionary<string, object>? Parameters) BuildSectionSpec(string key)
    {
        if (Provider == null || !Provider.TryGetSectionComponentType(key, out var componentType) || componentType == null)
        {
            return (null, null);
        }

        var vm = ResolveViewModel(key);
        if (vm == null)
        {
            return (null, null);
        }

        return (componentType, new Dictionary<string, object> { ["ViewModel"] = vm });
    }

    private object? ResolveViewModel(string key)
    {
        if (_viewModels.TryGetValue(key, out var existing))
        {
            return existing;
        }

        if (Provider == null)
        {
            return null;
        }

        var vm = Provider.CreateSectionViewModel(key, Services);

        if (vm != null)
        {
            _viewModels[key] = vm;
        }

        return vm;
    }
}
