@page "/help/view/{*HelpPath}"
@layout FinanceManager.Web.Components.Layout.HelpLayout
@using System.Globalization
@using FinanceManager.Web.Services.Help
@inject IHelpContentRenderer HelpContentRenderer
@inject IHelpAssetIntegrityValidator HelpAssetIntegrityValidator
@inject IWebHostEnvironment Environment

@{
    var lang = CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "de";
}

@if (isLoading)
{
    <div class="container mt-5">
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            @(lang == "en" ? "Loading..." : "Wird geladen...")
        </div>
    </div>
}
else if (error != null)
{
    <div class="container mt-5">
        <div class="alert alert-danger">
            <strong>@(lang == "en" ? "Error" : "Fehler"):</strong> @error
            <br />
            <small class="text-muted">HelpPath: @HelpPath</small>
        </div>
        <a class="btn btn-secondary" href="/help">
            ← @(lang == "en" ? "Back to Help" : "Zurück zur Hilfe")
        </a>
    </div>
}
else if (markdown != null)
{
    <div class="help-view-container">
        <div class="help-view-header">
            <a class="btn btn-secondary" href="/help">
                ← @(lang == "en" ? "Back to Help" : "Zurück zur Hilfe")
            </a>
        </div>

        <div class="help-view-content">
            @((MarkupString)markdown)
        </div>
    </div>
}

@code {
    [Parameter]
    public string? HelpPath { get; set; }

    private string? markdown;
    private string? error;
    private bool isLoading = true;
    private string language = "de";

    protected override async Task OnInitializedAsync()
    {
        language = CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "de";
        
        if (string.IsNullOrEmpty(HelpPath))
        {
            error = language == "en" ? "Feature ID is required" : "Feature ID ist erforderlich";
            isLoading = false;
            return;
        }

        try
        {
            // Load markdown from API
            if (!HelpDocumentPathResolver.TryNormalizeHelpPath(HelpPath, out var normalizedHelpPath))
            {
                error = language == "en" ? "Invalid help page" : "Ungueltige Hilfeseite";
                return;
            }

            var docsPath = HelpDocumentPathResolver.GetHelpSourcePath(Environment);
            var selectedFile = HelpDocumentPathResolver.FindMarkdownFile(docsPath, language, normalizedHelpPath);
            if (selectedFile is null || !File.Exists(selectedFile) || !HelpAssetIntegrityValidator.IsTrustedHelpFile(selectedFile))
            {
                error = language == "en" ? $"Help page not found: {HelpPath}" : $"Hilfeseite nicht gefunden: {HelpPath}";
                return;
            }

            var content = await File.ReadAllTextAsync(selectedFile, System.Text.Encoding.UTF8);
            var relativeDocumentPath = Path.GetRelativePath(docsPath, selectedFile).Replace('\\', '/');
            markdown = HelpContentRenderer.RenderMarkdownToHtml(content, relativeDocumentPath);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading help page: {ex.Message}");
            error = language == "en" ? "Error loading help page" : "Fehler beim Laden der Hilfeseite";
        }
        finally
        {
            isLoading = false;
        }
    }
}
