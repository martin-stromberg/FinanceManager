@using FinanceManager.Application
@using FinanceManager.Web.ViewModels.Securities.ReturnAnalysis
@inject IServiceProvider Services
@inject NavigationManager Nav

<div class="benchmark-tab">
    @if (_vm?.IsLoading == true) { <div role="status">Lade Benchmark-Daten...</div> }
    else if (_vm?.Data == null)
    {
        <div class="no-benchmark-hint">
            <p>Kein Benchmark konfiguriert.</p>
            <p>Sie können ein vorhandenes Wertpapier als Benchmark für alle Ihre Wertpapiere festlegen.</p>
            <button class="btn-primary" @onclick="NavigateToSettings">Benchmark festlegen</button>
        </div>
    }
    else
    {
        <div class="benchmark-chart-area">
            <p class="benchmark-name">Benchmark: <strong>@_vm.Data.BenchmarkName</strong></p>
            <div class="benchmark-legend">
                <span class="legend-item security">Dieses Wertpapier</span>
                <span class="legend-item benchmark">@_vm.Data.BenchmarkName</span>
            </div>
            @{
                var allValues = _vm.Data.SecurityNormalizedValues.Select(p => p.Value)
                    .Concat(_vm.Data.BenchmarkNormalizedValues.Select(p => p.Value));
                var maxVal = allValues.DefaultIfEmpty(100m).Max();
                var minVal = allValues.DefaultIfEmpty(0m).Min();
                var valueRange = maxVal - minVal;
                if (valueRange == 0) { valueRange = 1m; }
                var total = Math.Max(_vm.Data.SecurityNormalizedValues.Count, _vm.Data.BenchmarkNormalizedValues.Count);
            }
            <svg viewBox="0 0 @(Math.Max(total, 1)) 110" preserveAspectRatio="none" class="benchmark-svg" role="img" aria-label="Benchmark-Vergleichschart">
                <title>Benchmark-Vergleich</title>
                @{
                    var secPoints = string.Join(" ", _vm.Data.SecurityNormalizedValues.Select((p, i) =>
                        FormattableString.Invariant($"{i},{100m - (p.Value - minVal) / valueRange * 90m:F1}")));
                    var bmPoints = string.Join(" ", _vm.Data.BenchmarkNormalizedValues.Select((p, i) =>
                        FormattableString.Invariant($"{i},{100m - (p.Value - minVal) / valueRange * 90m:F1}")));
                }
                @if (!string.IsNullOrEmpty(secPoints))
                {
                    <polyline points="@secPoints" fill="none" stroke="#2d6cdf" stroke-width="0.8" />
                }
                @if (!string.IsNullOrEmpty(bmPoints))
                {
                    <polyline points="@bmPoints" fill="none" stroke="#e07b20" stroke-width="0.8" stroke-dasharray="3,2" />
                }
                @* X-axis baseline *@
                <line x1="0" y1="100" x2="@(Math.Max(total - 1, 1))" y2="100" stroke="#ccc" stroke-width="0.3" />
                @* Start date label *@
                <text x="0" y="108" font-size="5" fill="#888" text-anchor="start">@_vm.Data.StartDate.ToString("MM/yyyy")</text>
                @* End date label *@
                <text x="@(Math.Max(total - 1, 1))" y="108" font-size="5" fill="#888" text-anchor="end">@_vm.Data.EndDate.ToString("MM/yyyy")</text>
            </svg>
        </div>
    }
</div>

@code {
    /// <summary>Security identifier.</summary>
    [Parameter, EditorRequired] public Guid SecurityId { get; set; }

    private SecurityPerformanceBenchmarkTabViewModel? _vm;

    /// <inheritdoc />
    protected override Task OnInitializedAsync()
    {
        _vm = new SecurityPerformanceBenchmarkTabViewModel(Services);
        _vm.StateChanged += VmOnStateChanged;
        return Task.CompletedTask;
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        if (_vm == null)
        {
            return;
        }

        await _vm.LoadAsync(SecurityId, CancellationToken.None);
    }

    public void Dispose()
    {
        if (_vm != null)
        {
            _vm.StateChanged -= VmOnStateChanged;
        }
    }

    private void VmOnStateChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void NavigateToSettings()
    {
        Nav.NavigateTo("/card/setup?prefill=returnanalysis");
    }
}
