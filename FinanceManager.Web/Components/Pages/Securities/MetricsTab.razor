@using FinanceManager.Application
@using FinanceManager.Application.Securities.ReturnAnalysis
@inject IReturnAnalysisService ReturnAnalysis
@inject ICurrentUserService CurrentUser

<div class="metrics-tab">
    @if (_loading) { <div role="status">Lade Kennzahlen...</div> }
    else if (_data == null) { <div class="no-data-msg">Keine Kennzahlen verfügbar.</div> }
    else
    {
        <div class="kpi-grid">
            <div class="kpi-section">
                <h3>Rendite</h3>
                @KpiRow("Bruttorendite", _data.GrossReturn.ToString("N2") + " €", "Gesamtrendite vor Steuern und Gebühren")
                @KpiRow("Nettorendite", _data.NetReturn.ToString("N2") + " €", "Rendite nach Steuern")
                @KpiRow("TWR (zeitgewichtet)", _data.Twr.HasValue ? _data.Twr.Value.ToString("+0.00%;-0.00%") : "–", "Time-Weighted Return (Modified Dietz, GIPS-konform)")
                @KpiRow("IRR (persönlich)", _data.Irr.HasValue ? _data.Irr.Value.ToString("+0.00%;-0.00%") : "–", "Internal Rate of Return – Ihre persönliche Rendite")
                @if (_data.SharpeRatio.HasValue)
                {
                    @KpiRow("Sharpe Ratio", _data.SharpeRatio.Value.ToString("F2"), "(Rendite – risikofreier Zinssatz) / Volatilität")
                }
            </div>
            <div class="kpi-section">
                <h3>Risiko</h3>
                @KpiRow("Volatilität (p.a.)", _data.Volatility.HasValue ? _data.Volatility.Value.ToString("P2") : "–", "Annualisierte Standardabweichung der Log-Tagesrenditen")
                @KpiRow("Max. Drawdown", _data.MaxDrawdown.HasValue ? _data.MaxDrawdown.Value.ToString("P2") : "–", "Maximaler Verlust vom Höchststand")
            </div>
            <div class="kpi-section">
                <h3>Steuern &amp; Gebühren</h3>
                @KpiRow("Gezahlte Steuern", _data.TotalTaxes.ToString("N2") + " €")
                @KpiRow("Gezahlte Gebühren", _data.TotalFees.ToString("N2") + " €")
                @KpiRow("Steuerquote", _data.TaxRate.ToString("P1"))
            </div>
            <div class="kpi-section">
                <h3>Gewinne</h3>
                @KpiRow("Realisierte Gewinne", _data.RealizedGains.ToString("N2") + " €", "Realisierte Kursgewinne (FIFO)")
                @KpiRow("Nicht realisierte Gewinne", _data.UnrealizedGains.ToString("N2") + " €", "Buchgewinne auf aktuelle Positionen")
                @KpiRow("Dividendenrendite akt. Jahr", _data.DividendYieldCurrentYear.ToString("P2"))
            </div>
        </div>
    }
</div>

@code {
    /// <summary>Security identifier.</summary>
    [Parameter, EditorRequired] public Guid SecurityId { get; set; }

    private DetailedReturnMetricsDto? _data;
    private bool _loading = true;

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        try { _data = await ReturnAnalysis.GetDetailedMetricsAsync(SecurityId, CurrentUser.UserId, CancellationToken.None); }
        finally { _loading = false; }
    }

    private RenderFragment KpiRow(string label, string value, string? tooltip = null) => __builder =>
    {
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class", "kpi-row");
        if (!string.IsNullOrEmpty(tooltip)) { __builder.AddAttribute(2, "title", tooltip); }
        __builder.OpenElement(3, "span");
        __builder.AddAttribute(4, "class", "kpi-label");
        __builder.AddContent(5, label);
        if (!string.IsNullOrEmpty(tooltip)) { __builder.AddContent(6, " ⓘ"); }
        __builder.CloseElement();
        __builder.OpenElement(7, "span");
        __builder.AddAttribute(8, "class", "kpi-value");
        __builder.AddContent(9, value);
        __builder.CloseElement();
        __builder.CloseElement();
    };
}
