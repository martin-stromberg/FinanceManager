@using FinanceManager.Application
@using FinanceManager.Application.Securities.ReturnAnalysis
@inject IReturnAnalysisService ReturnAnalysis
@inject ICurrentUserService CurrentUser

<div class="overview-tab">
    <div class="time-range-selector">
        @foreach (var range in _ranges)
        {
            <button class="range-btn @(_selectedRange == range ? "active" : "")"
                    @onclick="(() => SelectRangeAsync(range))">
                @GetRangeLabel(range)
            </button>
        }
    </div>

    @if (_loading)
    {
        <div class="chart-placeholder" role="status">Lade Chartdaten...</div>
    }
    else if (_data == null || _data.PortfolioValues.Count == 0)
    {
        <div class="no-data-msg">Keine Kursdaten für den gewählten Zeitraum vorhanden.</div>
    }
    else
    {
        <div class="perf-chart-area">
            <div class="chart-legend">
                <span class="legend-item portfolio">Marktwert</span>
                <span class="legend-item invested">Investiert</span>
            </div>
            <div class="simple-line-chart" aria-label="Performance-Chart">
                @{
                    var allValues = _data.PortfolioValues.Select(p => p.Value)
                        .Concat(_data.InvestedCapitalValues.Select(p => p.Value));
                    var maxVal = allValues.DefaultIfEmpty(1m).Max();
                    var minVal = allValues.DefaultIfEmpty(0m).Min();
                    var valueRange = maxVal - minVal;
                    if (valueRange == 0) { valueRange = 1m; }
                    var total = _data.PortfolioValues.Count;
                }
                <svg viewBox="0 0 @total 100" preserveAspectRatio="none" class="perf-svg" role="img">
                    <title>Portfolio-Wertentwicklung</title>
                    @{
                        var portfolioPoints = string.Join(" ", _data.PortfolioValues.Select((p, i) =>
                            $"{i},{100m - (p.Value - minVal) / valueRange * 95m:F1}"));
                        var investedPoints = string.Join(" ", _data.InvestedCapitalValues.Select((p, i) =>
                            $"{i},{100m - (p.Value - minVal) / valueRange * 95m:F1}"));
                    }
                    @if (!string.IsNullOrEmpty(portfolioPoints))
                    {
                        <polyline points="@portfolioPoints" fill="none" stroke="#2d6cdf" stroke-width="0.8" />
                    }
                    @if (!string.IsNullOrEmpty(investedPoints))
                    {
                        <polyline points="@investedPoints" fill="none" stroke="#999" stroke-width="0.6" stroke-dasharray="2,2" />
                    }
                </svg>
                <div class="chart-dates">
                    <span>@(_data.PortfolioValues.FirstOrDefault()?.Date.ToString("dd.MM.yy"))</span>
                    <span>@(_data.PortfolioValues.LastOrDefault()?.Date.ToString("dd.MM.yy"))</span>
                </div>
            </div>
        </div>
    }
</div>

@code {
    /// <summary>Security identifier.</summary>
    [Parameter, EditorRequired] public Guid SecurityId { get; set; }

    private static readonly ChartTimeRange[] _ranges =
    [
        ChartTimeRange.OneMonth, ChartTimeRange.ThreeMonths, ChartTimeRange.SixMonths,
        ChartTimeRange.OneYear, ChartTimeRange.ThreeYears, ChartTimeRange.All
    ];

    private ChartTimeRange _selectedRange = ChartTimeRange.OneYear;
    private PerformanceChartDataDto? _data;
    private bool _loading = true;

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync(_selectedRange);
    }

    private async Task SelectRangeAsync(ChartTimeRange range)
    {
        _selectedRange = range;
        await LoadAsync(range);
    }

    private async Task LoadAsync(ChartTimeRange range)
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await ReturnAnalysis.GetPerformanceChartDataAsync(SecurityId, CurrentUser.UserId, range, CancellationToken.None);
        }
        finally { _loading = false; StateHasChanged(); }
    }

    private static string GetRangeLabel(ChartTimeRange range) => range switch
    {
        ChartTimeRange.OneMonth => "1M",
        ChartTimeRange.ThreeMonths => "3M",
        ChartTimeRange.SixMonths => "6M",
        ChartTimeRange.OneYear => "1J",
        ChartTimeRange.ThreeYears => "3J",
        ChartTimeRange.All => "Gesamt",
        _ => range.ToString()
    };
}
