@using FinanceManager.Application
@using FinanceManager.Web.ViewModels.Securities.ReturnAnalysis
@inject IServiceProvider Services

<div class="overview-tab">
    <div class="time-range-selector">
        @if (_vm != null)
        {
            @foreach (var range in _vm.Ranges)
            {
                <button class="range-btn @(_vm.SelectedRange == range ? "active" : "")"
                        @onclick="(() => _vm.SelectRangeAsync(range, CancellationToken.None))">
                    @SecurityPerformanceOverviewTabViewModel.GetRangeLabel(range)
                </button>
            }
        }
    </div>

    @if (_vm?.IsLoading == true)
    {
        <div class="chart-placeholder" role="status">Lade Chartdaten...</div>
    }
    else if (_vm?.Data == null || _vm.Data.PortfolioValues.Count == 0)
    {
        <div class="no-data-msg">Keine Kursdaten für den gewählten Zeitraum vorhanden.</div>
    }
    else
    {
        <div class="perf-chart-area">
            <div class="chart-legend">
                <span class="legend-item portfolio">Marktwert</span>
                <span class="legend-item invested">Investiert</span>
            </div>
            <div class="simple-line-chart" aria-label="Performance-Chart">
                @{
                    var allValues = _vm.Data.PortfolioValues.Select(p => p.Value)
                        .Concat(_vm.Data.InvestedCapitalValues.Select(p => p.Value));
                    var maxVal = allValues.DefaultIfEmpty(1m).Max();
                    var minVal = allValues.DefaultIfEmpty(0m).Min();
                    var valueRange = maxVal - minVal;
                    if (valueRange == 0) { valueRange = 1m; }
                    var total = _vm.Data.PortfolioValues.Count;
                }
                <svg viewBox="0 0 @total 100" preserveAspectRatio="none" class="perf-svg" role="img">
                    <title>Portfolio-Wertentwicklung</title>
                    @{
                        var portfolioPoints = string.Join(" ", _vm.Data.PortfolioValues.Select((p, i) =>
                            $"{i},{100m - (p.Value - minVal) / valueRange * 95m:F1}"));
                        var investedPoints = string.Join(" ", _vm.Data.InvestedCapitalValues.Select((p, i) =>
                            $"{i},{100m - (p.Value - minVal) / valueRange * 95m:F1}"));
                    }
                    @if (!string.IsNullOrEmpty(portfolioPoints))
                    {
                        <polyline points="@portfolioPoints" fill="none" stroke="#2d6cdf" stroke-width="0.8" />
                    }
                    @if (!string.IsNullOrEmpty(investedPoints))
                    {
                        <polyline points="@investedPoints" fill="none" stroke="#999" stroke-width="0.6" stroke-dasharray="2,2" />
                    }
                </svg>
                <div class="chart-dates">
                    <span>@(_vm.Data.PortfolioValues.FirstOrDefault()?.Date.ToString("dd.MM.yy"))</span>
                    <span>@(_vm.Data.PortfolioValues.LastOrDefault()?.Date.ToString("dd.MM.yy"))</span>
                </div>
            </div>
        </div>
    }
</div>

@code {
    /// <summary>Security identifier.</summary>
    [Parameter, EditorRequired] public Guid SecurityId { get; set; }

    private SecurityPerformanceOverviewTabViewModel? _vm;

    /// <inheritdoc />
    protected override Task OnInitializedAsync()
    {
        _vm = new SecurityPerformanceOverviewTabViewModel(Services);
        _vm.StateChanged += VmOnStateChanged;
        return Task.CompletedTask;
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        if (_vm == null)
        {
            return;
        }

        await _vm.LoadAsync(SecurityId, CancellationToken.None);
    }

    public void Dispose()
    {
        if (_vm != null)
        {
            _vm.StateChanged -= VmOnStateChanged;
        }
    }

    private void VmOnStateChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
