@using Microsoft.AspNetCore.Components
@using FinanceManager.Shared.Dtos.Update
@rendermode InteractiveServer
@inject FinanceManager.Application.ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject FinanceManager.Web.Services.Updates.IInstalledReleaseMetadataProvider ReleaseMetadata

@if (CurrentUser.IsAuthenticated)
{
    <div class="login-status">@DisplayVersion<br />
        <button @onclick="LogoutAsync">Logout</button>
    </div>
}
else
{
    <div class="login-status"><a href="/login">Login</a></div>
}

@code {
    private InstalledReleaseMetadataDto? _versionInfo;

    private string DisplayVersion => string.IsNullOrEmpty(_versionInfo?.Version)
        ? "Version unbekannt"
        : _versionInfo.Version;

    protected override async Task OnInitializedAsync()
    {
        _versionInfo = await ReleaseMetadata.GetAsync();
    }

    private async Task LogoutAsync()
    {
        var ok = await JS.InvokeAsync<bool>("fmAuthLogout");
        // Fallback: falls API nicht erreichbar, erzwungener Reload l�scht serverseitig nicht gesetzte Cookies evtl. nicht, aber UI wird zur Login-Seite gehen
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
