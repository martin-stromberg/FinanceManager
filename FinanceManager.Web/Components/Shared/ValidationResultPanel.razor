@using FinanceManager.Shared.Dtos.Statements
@inject Microsoft.Extensions.Localization.IStringLocalizer<FinanceManager.Web.Pages> Localizer
@using FinanceManager.Web.Components.Statements
@using Microsoft.AspNetCore.Components
@inject NavigationManager NavigationManager

@inherits ComponentBase

@if (ValidationResult == null)
{
    <div></div>
}
else
{
    <div style="padding:.5rem;border:1px solid var(--border);border-radius:6px;background:var(--panel-bg);">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem;">
            <div style="font-weight:600;">@Localizer?["Validation_Header"]</div>
            <div>
                <button class="icon-btn" title="@Localizer?["Btn_Close"]" @onclick="Close"> <svg><use href="/icons/sprite.svg#clear"/></svg></button>
            </div>
        </div>
        <div style="margin-bottom:.5rem;">@((ValidationResult.IsValid) ? (Localizer?["Validation_Valid"] ?? "No errors found") : (Localizer?["Validation_Invalid"] ?? "Issues found"))</div>
        <ul style="margin:0;padding-left:1.25rem;">
            @foreach (var m in ValidationResult.Messages.Where(e => e.EntryId is null))
            {
                <li style="margin:.25rem 0;">
                    @($"[{m.Severity}] {m.Message}")
                    @{
                        var relatedRecordUrl = BuildRelatedRecordUrl(m);
                    }
                    @if (!string.IsNullOrWhiteSpace(relatedRecordUrl))
                    {
                        <a href="@relatedRecordUrl" style="margin-left:.5rem;">@(Localizer?["Validation_OpenRelatedRecord"] ?? "Open record")</a>
                    }
                </li>
            }
        </ul>

        @* If there are any messages (warnings/errors) offer action buttons: proceed (ignore warnings) and close *@
        @if (ValidationResult.Messages != null && ValidationResult.Messages.Any() && AllowProceed)
        {
            <div style="display:flex;gap:.5rem;margin-top:.6rem;justify-content:flex-end;">
            <button class="btn btn-secondary" @onclick="Close">@Localizer?["Validation_Close"]</button>
                <button class="btn btn-primary" @onclick="ProceedIgnoreWarnings">@Localizer?["Validation_Proceed"]</button>
            </div>
        }

        @* Budget Impact Panel - shows budget changes discovered during validation *@
        <BudgetImpactValidationPanel ValidationResult="@ValidationResult" />
    </div>
}

@code {
    [Parameter] public DraftValidationResultDto? ValidationResult { get; set; }
    [Parameter] public bool AllowProceed { get; set; } = false;

    [CascadingParameter(Name = "EmbeddedClose")] public Action? EmbeddedClose { get; set; }
    [CascadingParameter(Name = "EmbeddedOnFinished")] public Action<object>? EmbeddedOnFinished { get; set; }

    private void Close()
    {
        EmbeddedClose?.Invoke();
    }

    private void ProceedIgnoreWarnings()
    {
        // Signal host that user confirmed proceeding despite warnings
        try
        {
            EmbeddedOnFinished?.Invoke(new { Confirm = true });
        }
        finally
        {
            EmbeddedClose?.Invoke();
        }
    }

    private string? BuildRelatedRecordUrl(DraftValidationMessageDto message)
    {
        if (string.IsNullOrWhiteSpace(message.RelatedRecordKind) || message.RelatedRecordId is null || message.RelatedRecordId == Guid.Empty)
        {
            return null;
        }

        var kind = message.RelatedRecordKind.Trim().Trim('/');
        if (string.IsNullOrWhiteSpace(kind))
        {
            return null;
        }

        var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var currentUrl = "/" + currentPath;
        return $"/card/{kind}/{message.RelatedRecordId}?back={Uri.EscapeDataString(currentUrl)}";
    }
}
